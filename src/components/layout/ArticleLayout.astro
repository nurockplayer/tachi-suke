---
import BaseLayout from "./BaseLayout.astro";
import { formatDate } from "@/lib/content";
import { htmlLangByLocale, localizePath, type Locale } from "@/lib/i18n";

interface Props {
  locale: Locale;
  title: string;
  description: string;
  category: string;
  tags: string[];
  publishedAt: Date;
  updatedAt: Date;
  alternatePaths?: Partial<Record<Locale, string>>;
}

const { locale, title, description, category, tags, publishedAt, updatedAt, alternatePaths } = Astro.props;
const site = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = new URL(Astro.url.pathname, site).href;
const localeHomeUrl = new URL(localizePath(locale), site).href;
const articlesUrl = new URL(localizePath(locale, "/articles"), site).href;
const updatedLabel = {
  "zh-tw": "更新",
  en: "Updated",
  ja: "更新",
  ko: "업데이트"
}[locale];
const articlesLabel = {
  "zh-tw": "文章",
  en: "Articles",
  ja: "記事",
  ko: "글"
}[locale];
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${canonicalUrl}#article`,
    mainEntityOfPage: canonicalUrl,
    headline: title,
    description,
    articleSection: category,
    keywords: tags,
    datePublished: publishedAt.toISOString(),
    dateModified: updatedAt.toISOString(),
    inLanguage: htmlLangByLocale[locale],
    publisher: { "@id": new URL("/#organization", site).href }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${canonicalUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "TachiSuke",
        item: localeHomeUrl
      },
      {
        "@type": "ListItem",
        position: 2,
        name: articlesLabel,
        item: articlesUrl
      },
      {
        "@type": "ListItem",
        position: 3,
        name: title,
        item: canonicalUrl
      }
    ]
  }
];
---

<BaseLayout locale={locale} title={title} description={description} alternatePaths={alternatePaths} ogType="article" jsonLd={jsonLd}>
  <article class="article-shell narrow">
    <header class="article-header">
      <p class="article-meta">{category} · {formatDate(publishedAt, locale)} · {updatedLabel} {formatDate(updatedAt, locale)}</p>
      <h1>{title}</h1>
      <p>{description}</p>
      <ul class="tag-list" aria-label="Tags">
        {tags.map((tag) => <li>{tag}</li>)}
      </ul>
    </header>
    <div class="article-body">
      <slot />
    </div>
  </article>
</BaseLayout>
