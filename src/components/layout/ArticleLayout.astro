---
import BaseLayout from "./BaseLayout.astro";
import CorrectionPrompt from "@/components/content/CorrectionPrompt.astro";
import Breadcrumbs from "@/components/navigation/Breadcrumbs.astro";
import { formatDate } from "@/lib/content";
import { getArticleCategoryTitle, slugifyArticleCategory } from "@/lib/content/article-categories";
import { getUiCopy, htmlLangByLocale, localizePath, type Locale } from "@/lib/i18n";
import type { ArticleSourceLink } from "@/types/article";

interface RelatedArticleLink {
  title: string;
  description: string;
  href: string;
}

interface ArticleHeading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  locale: Locale;
  title: string;
  description: string;
  category: string;
  tags: string[];
  publishedAt: Date;
  updatedAt: Date;
  alternatePaths?: Partial<Record<Locale, string>>;
  headings?: ArticleHeading[];
  relatedArticles?: RelatedArticleLink[];
  sourceLinks?: ArticleSourceLink[];
}

const {
  locale,
  title,
  description,
  category,
  tags,
  publishedAt,
  updatedAt,
  alternatePaths,
  headings = [],
  relatedArticles = [],
  sourceLinks = []
} = Astro.props;
const site = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = new URL(Astro.url.pathname, site).href;
const localeHomeUrl = new URL(localizePath(locale), site).href;
const articlesUrl = new URL(localizePath(locale, "/articles"), site).href;
const categoryHref = localizePath(locale, `/articles/category/${slugifyArticleCategory(category)}`);
const categoryUrl = new URL(categoryHref, site).href;
const categoryTitle = getArticleCategoryTitle(locale, category);
const tagListLabel = getUiCopy(locale, "layout.tagList");
const updatedLabel = {
  "zh-tw": "更新",
  en: "Updated",
  ja: "更新",
  ko: "업데이트"
}[locale];
const trustCopy = {
  "zh-tw": {
    title: "資訊可能會變動",
    body: "本文是生活決策用的整理。手機方案、行政手續、租屋與工作規則可能更新，申請或辦理前請再確認官方網站、窗口或店家最新資訊。",
    ariaLabel: "文章更新與查證提醒"
  },
  en: {
    title: "Information can change",
    body: "This guide is editorial decision support. Mobile plans, procedures, housing terms, and work rules may change, so confirm the latest official, counter, or store information before applying or acting.",
    ariaLabel: "Article freshness and verification notice"
  },
  ja: {
    title: "情報は変わることがあります",
    body: "この記事は生活判断のための編集ガイドです。携帯プラン、行政手続き、住まい、仕事に関する条件は変わることがあるため、申し込みや手続きの前に公式サイト、窓口、店舗の最新情報を確認してください。",
    ariaLabel: "記事の更新と確認に関する注意"
  },
  ko: {
    title: "정보는 바뀔 수 있습니다",
    body: "이 글은 생활 결정을 돕기 위한 편집 가이드입니다. 휴대폰 요금제, 행정 절차, 주거 조건, 근무 관련 규칙은 바뀔 수 있으니 신청하거나 진행하기 전에 공식 사이트, 창구, 매장의 최신 정보를 확인하세요.",
    ariaLabel: "글 업데이트 및 확인 안내"
  }
}[locale];
const articlesLabel = {
  "zh-tw": "文章",
  en: "Articles",
  ja: "記事",
  ko: "글"
}[locale];
const relatedCopy = {
  "zh-tw": {
    title: "相關文章",
    description: "接著閱讀同語言的實用指南。"
  },
  en: {
    title: "Related guides",
    description: "Keep reading practical guides in the same language."
  },
  ja: {
    title: "関連ガイド",
    description: "同じ言語の実用ガイドを続けて読めます。"
  },
  ko: {
    title: "관련 가이드",
    description: "같은 언어의 실용 가이드를 이어서 읽어보세요."
  }
}[locale];
const tocCopy = {
  "zh-tw": {
    title: "本文目錄",
    description: "快速跳到你需要的段落。"
  },
  en: {
    title: "On this page",
    description: "Jump to the section you need."
  },
  ja: {
    title: "この記事の目次",
    description: "必要なセクションへ移動できます。"
  },
  ko: {
    title: "이 글의 목차",
    description: "필요한 부분으로 바로 이동하세요."
  }
}[locale];
const sourceCopy = {
  "zh-tw": {
    title: "官方確認入口",
    description: "行動前請以官方網站、窗口或店家最新資訊為準。"
  },
  en: {
    title: "Official confirmation links",
    description: "Use these as starting points, then confirm the latest official, counter, or store information before acting."
  },
  ja: {
    title: "公式確認リンク",
    description: "行動する前に、公式サイト、窓口、店舗の最新情報を確認してください。"
  },
  ko: {
    title: "공식 확인 링크",
    description: "진행하기 전에 공식 사이트, 창구, 매장의 최신 정보를 확인하세요."
  }
}[locale];
const tocHeadings = headings
  .filter((heading) => heading.depth >= 2 && heading.depth <= 3 && heading.slug && heading.text)
  .slice(0, 12);
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${canonicalUrl}#article`,
    mainEntityOfPage: canonicalUrl,
    headline: title,
    description,
    articleSection: categoryTitle,
    keywords: tags,
    datePublished: publishedAt.toISOString(),
    dateModified: updatedAt.toISOString(),
    inLanguage: htmlLangByLocale[locale],
    publisher: { "@id": new URL("/#organization", site).href }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${canonicalUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "TachiSuke",
        item: localeHomeUrl
      },
      {
        "@type": "ListItem",
        position: 2,
        name: articlesLabel,
        item: articlesUrl
      },
      {
        "@type": "ListItem",
        position: 3,
        name: categoryTitle,
        item: categoryUrl
      },
      {
        "@type": "ListItem",
        position: 4,
        name: title,
        item: canonicalUrl
      }
    ]
  }
];
const articleOpenGraph = {
  publishedAt,
  updatedAt,
  section: categoryTitle,
  tags
};
---

<BaseLayout locale={locale} title={title} description={description} alternatePaths={alternatePaths} ogType="article" articleOpenGraph={articleOpenGraph} jsonLd={jsonLd}>
  <article class="article-shell narrow">
    <header class="article-header">
      <Breadcrumbs
        locale={locale}
        items={[
          { label: "TachiSuke", href: localizePath(locale) },
          { label: articlesLabel, href: localizePath(locale, "/articles") },
          { label: categoryTitle, href: categoryHref },
          { label: title }
        ]}
      />
      <p class="article-meta">
        <a class="article-meta-link" href={categoryHref}>{categoryTitle}</a>
        {" · "}
        <time datetime={publishedAt.toISOString()}>{formatDate(publishedAt, locale)}</time>
        {" · "}
        {updatedLabel} <time datetime={updatedAt.toISOString()}>{formatDate(updatedAt, locale)}</time>
      </p>
      <h1>{title}</h1>
      <p>{description}</p>
      <ul class="tag-list" aria-label={tagListLabel}>
        {tags.map((tag) => <li>{tag}</li>)}
      </ul>
    </header>
    <aside class="article-trust-notice" data-article-trust-notice aria-label={trustCopy.ariaLabel}>
      <strong>{trustCopy.title}</strong>
      <p>{trustCopy.body}</p>
    </aside>
    {sourceLinks.length > 0 && (
      <aside class="article-source-links" data-article-source-links aria-labelledby="article-source-links-title">
        <div>
          <h2 id="article-source-links-title">{sourceCopy.title}</h2>
          <p>{sourceCopy.description}</p>
        </div>
        <ul>
          {sourceLinks.map((sourceLink) => (
            <li>
              <a href={sourceLink.url} target="_blank" rel="noreferrer">{sourceLink.label}</a>
              {sourceLink.note && <span>{sourceLink.note}</span>}
            </li>
          ))}
        </ul>
      </aside>
    )}
    {tocHeadings.length >= 2 && (
      <nav class="article-toc" aria-labelledby="article-toc-title">
        <div>
          <h2 id="article-toc-title">{tocCopy.title}</h2>
          <p>{tocCopy.description}</p>
        </div>
        <ol>
          {tocHeadings.map((heading) => (
            <li class={`toc-depth-${heading.depth}`}>
              <a href={`#${heading.slug}`}>{heading.text}</a>
            </li>
          ))}
        </ol>
      </nav>
    )}
    <div class="article-body">
      <slot />
    </div>
    <CorrectionPrompt locale={locale} currentPath={Astro.url.pathname} />
    {relatedArticles.length > 0 && (
      <aside class="related-articles" aria-labelledby="related-articles-title">
        <div>
          <h2 id="related-articles-title">{relatedCopy.title}</h2>
          <p>{relatedCopy.description}</p>
        </div>
        <div class="related-article-list">
          {relatedArticles.map((relatedArticle) => (
            <a class="related-article-card" href={relatedArticle.href}>
              <strong>{relatedArticle.title}</strong>
              <span>{relatedArticle.description}</span>
            </a>
          ))}
        </div>
      </aside>
    )}
  </article>
</BaseLayout>
