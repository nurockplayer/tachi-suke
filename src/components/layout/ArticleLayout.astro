---
import BaseLayout from "./BaseLayout.astro";
import CorrectionPrompt from "@/components/content/CorrectionPrompt.astro";
import Breadcrumbs from "@/components/navigation/Breadcrumbs.astro";
import { formatDate } from "@/lib/content";
import { slugifyArticleCategory } from "@/lib/content/article-categories";
import { htmlLangByLocale, localizePath, type Locale } from "@/lib/i18n";

interface RelatedArticleLink {
  title: string;
  description: string;
  href: string;
}

interface ArticleHeading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  locale: Locale;
  title: string;
  description: string;
  category: string;
  tags: string[];
  publishedAt: Date;
  updatedAt: Date;
  alternatePaths?: Partial<Record<Locale, string>>;
  headings?: ArticleHeading[];
  relatedArticles?: RelatedArticleLink[];
}

const { locale, title, description, category, tags, publishedAt, updatedAt, alternatePaths, headings = [], relatedArticles = [] } = Astro.props;
const site = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = new URL(Astro.url.pathname, site).href;
const localeHomeUrl = new URL(localizePath(locale), site).href;
const articlesUrl = new URL(localizePath(locale, "/articles"), site).href;
const categoryHref = localizePath(locale, `/articles/category/${slugifyArticleCategory(category)}`);
const categoryUrl = new URL(categoryHref, site).href;
const updatedLabel = {
  "zh-tw": "更新",
  en: "Updated",
  ja: "更新",
  ko: "업데이트"
}[locale];
const articlesLabel = {
  "zh-tw": "文章",
  en: "Articles",
  ja: "記事",
  ko: "글"
}[locale];
const relatedCopy = {
  "zh-tw": {
    title: "相關文章",
    description: "接著閱讀同語言的實用指南。"
  },
  en: {
    title: "Related guides",
    description: "Keep reading practical guides in the same language."
  },
  ja: {
    title: "関連ガイド",
    description: "同じ言語の実用ガイドを続けて読めます。"
  },
  ko: {
    title: "관련 가이드",
    description: "같은 언어의 실용 가이드를 이어서 읽어보세요."
  }
}[locale];
const tocCopy = {
  "zh-tw": {
    title: "本文目錄",
    description: "快速跳到你需要的段落。"
  },
  en: {
    title: "On this page",
    description: "Jump to the section you need."
  },
  ja: {
    title: "この記事の目次",
    description: "必要なセクションへ移動できます。"
  },
  ko: {
    title: "이 글의 목차",
    description: "필요한 부분으로 바로 이동하세요."
  }
}[locale];
const tocHeadings = headings
  .filter((heading) => heading.depth >= 2 && heading.depth <= 3 && heading.slug && heading.text)
  .slice(0, 12);
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${canonicalUrl}#article`,
    mainEntityOfPage: canonicalUrl,
    headline: title,
    description,
    articleSection: category,
    keywords: tags,
    datePublished: publishedAt.toISOString(),
    dateModified: updatedAt.toISOString(),
    inLanguage: htmlLangByLocale[locale],
    publisher: { "@id": new URL("/#organization", site).href }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${canonicalUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "TachiSuke",
        item: localeHomeUrl
      },
      {
        "@type": "ListItem",
        position: 2,
        name: articlesLabel,
        item: articlesUrl
      },
      {
        "@type": "ListItem",
        position: 3,
        name: category,
        item: categoryUrl
      },
      {
        "@type": "ListItem",
        position: 4,
        name: title,
        item: canonicalUrl
      }
    ]
  }
];
const articleOpenGraph = {
  publishedAt,
  updatedAt,
  section: category,
  tags
};
---

<BaseLayout locale={locale} title={title} description={description} alternatePaths={alternatePaths} ogType="article" articleOpenGraph={articleOpenGraph} jsonLd={jsonLd}>
  <article class="article-shell narrow">
    <header class="article-header">
      <Breadcrumbs
        locale={locale}
        items={[
          { label: "TachiSuke", href: localizePath(locale) },
          { label: articlesLabel, href: localizePath(locale, "/articles") },
          { label: category, href: categoryHref },
          { label: title }
        ]}
      />
      <p class="article-meta"><a class="article-meta-link" href={categoryHref}>{category}</a> · {formatDate(publishedAt, locale)} · {updatedLabel} {formatDate(updatedAt, locale)}</p>
      <h1>{title}</h1>
      <p>{description}</p>
      <ul class="tag-list" aria-label="Tags">
        {tags.map((tag) => <li>{tag}</li>)}
      </ul>
    </header>
    {tocHeadings.length >= 2 && (
      <nav class="article-toc" aria-labelledby="article-toc-title">
        <div>
          <h2 id="article-toc-title">{tocCopy.title}</h2>
          <p>{tocCopy.description}</p>
        </div>
        <ol>
          {tocHeadings.map((heading) => (
            <li class={`toc-depth-${heading.depth}`}>
              <a href={`#${heading.slug}`}>{heading.text}</a>
            </li>
          ))}
        </ol>
      </nav>
    )}
    <div class="article-body">
      <slot />
    </div>
    <CorrectionPrompt locale={locale} currentPath={Astro.url.pathname} />
    {relatedArticles.length > 0 && (
      <aside class="related-articles" aria-labelledby="related-articles-title">
        <div>
          <h2 id="related-articles-title">{relatedCopy.title}</h2>
          <p>{relatedCopy.description}</p>
        </div>
        <div class="related-article-list">
          {relatedArticles.map((relatedArticle) => (
            <a class="related-article-card" href={relatedArticle.href}>
              <strong>{relatedArticle.title}</strong>
              <span>{relatedArticle.description}</span>
            </a>
          ))}
        </div>
      </aside>
    )}
  </article>
</BaseLayout>
