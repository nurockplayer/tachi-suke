---
import LocaleSwitcher from "./LocaleSwitcher.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { localizePath, navItems, type Locale } from "@/lib/i18n";

interface Props {
  locale: Locale;
  currentPath: string;
  alternatePaths?: Partial<Record<Locale, string>>;
}

const { locale, currentPath, alternatePaths } = Astro.props;
const accountLabel = {
  "zh-tw": "帳號",
  en: "Account",
  ja: "アカウント",
  ko: "계정"
}[locale];
const normalizedCurrentPath = currentPath.length > 1 ? currentPath.replace(/\/$/, "") : currentPath;
const navLinks = navItems[locale].map((item) => {
  const href = localizePath(locale, item.href);
  const normalizedHref = href.length > 1 ? href.replace(/\/$/, "") : href;
  const isActive = normalizedCurrentPath === normalizedHref || normalizedCurrentPath.startsWith(`${normalizedHref}/`);

  return { ...item, href, isActive };
});
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand-link" href={localizePath(locale)}>
      <span class="brand-mark" aria-hidden="true">立</span>
      <span>
        TachiSuke
        <span class="brand-subtitle">Japan Life Assistant</span>
      </span>
    </a>
    <nav class="header-nav" aria-label="Primary">
      {navLinks.map((item) => (
        <a href={item.href} aria-current={item.isActive ? "page" : undefined}>{item.label}</a>
      ))}
    </nav>
    <div class="header-tools">
      <LocaleSwitcher locale={locale} currentPath={currentPath} alternatePaths={alternatePaths} />
      <ThemeToggle locale={locale} />
      <a class="button-secondary" href={localizePath(locale, "/account/login")}>{accountLabel}</a>
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    if (window.__tachiSukeHeaderControlsReady) return;
    window.__tachiSukeHeaderControlsReady = true;

    const getOpenControls = () => document.querySelectorAll("details[data-global-control][open]");

    document.addEventListener("toggle", (event) => {
      const current = event.target instanceof HTMLDetailsElement ? event.target : null;
      if (!current?.matches("[data-global-control]") || !current.open) return;

      getOpenControls().forEach((control) => {
        if (control !== current) {
          control.removeAttribute("open");
        }
      });
    }, true);

    document.addEventListener("click", (event) => {
      const target = event.target instanceof Element ? event.target : null;
      if (target?.closest("[data-global-control]")) return;
      getOpenControls().forEach((control) => control.removeAttribute("open"));
    });

    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") return;
      getOpenControls().forEach((control) => control.removeAttribute("open"));
    });
  })();
</script>
