---
import { localeNames, locales, localizePath, type Locale } from "@/lib/i18n";

interface Props {
  locale: Locale;
  currentPath: string;
  alternatePaths?: Partial<Record<Locale, string>>;
}

const { locale, currentPath, alternatePaths } = Astro.props;
const pathWithoutLocale = currentPath.replace(/^\/(zh-tw|en|ja|ko)/, "") || "/";
const switcherPaths = alternatePaths ?? Object.fromEntries(locales.map((targetLocale) => [
  targetLocale,
  localizePath(targetLocale, pathWithoutLocale)
])) as Partial<Record<Locale, string>>;
---

<nav class="locale-switcher" aria-label="Language">
  {locales.map((targetLocale) => switcherPaths[targetLocale] && (
    <a
      href={switcherPaths[targetLocale]}
      aria-current={targetLocale === locale ? "true" : undefined}
    >
      {localeNames[targetLocale]}
    </a>
  ))}
</nav>
