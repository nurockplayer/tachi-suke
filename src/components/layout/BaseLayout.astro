---
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import { getPageTitle, htmlLangByLocale, locales, localizePath, type Locale } from "@/lib/i18n";
import "@/styles/global.css";

interface Props {
  locale: Locale;
  title?: string;
  description: string;
  alternatePaths?: Partial<Record<Locale, string>>;
  robots?: string;
  ogImage?: string;
  ogType?: "website" | "article";
}

const { locale, title, description, alternatePaths, robots, ogImage = "/images/og-default.svg", ogType = "website" } = Astro.props;
const site = Astro.site ?? new URL(Astro.url.origin);
const pageTitle = getPageTitle(locale, title);
const canonical = new URL(Astro.url.pathname, site);
const ogImageUrl = new URL(ogImage, site);
const pathWithoutLocale = Astro.url.pathname.replace(/^\/(zh-tw|en|ja|ko)/, "") || "/";
const alternates = alternatePaths ?? Object.fromEntries(locales.map((alternateLocale) => [
  alternateLocale,
  localizePath(alternateLocale, pathWithoutLocale)
])) as Partial<Record<Locale, string>>;
---

<!doctype html>
<html lang={htmlLangByLocale[locale]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonical.href} />
    {locales.map((alternateLocale) => alternates[alternateLocale] && (
      <link
        rel="alternate"
        hreflang={htmlLangByLocale[alternateLocale]}
        href={new URL(alternates[alternateLocale] ?? "/", site).href}
      />
    ))}
    {alternates.en && <link rel="alternate" hreflang="x-default" href={new URL(alternates.en, site).href} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:site_name" content="TachiSuke" />
    <meta property="og:image" content={ogImageUrl.href} />
    <meta property="og:image:alt" content="TachiSuke - Japan Life Assistant" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl.href} />
  </head>
  <body>
    <Header locale={locale} currentPath={Astro.url.pathname} alternatePaths={alternates} />
    <main class="site-main">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
