---
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import { getPageTitle, getUiCopy, htmlLangByLocale, locales, localizePath, type Locale } from "@/lib/i18n";
import "@/styles/global.css";

type JsonLdObject = Record<string, unknown>;

interface Props {
  locale: Locale;
  title?: string;
  description: string;
  alternatePaths?: Partial<Record<Locale, string>>;
  robots?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  jsonLd?: JsonLdObject | JsonLdObject[];
}

const { locale, title, description, alternatePaths, robots, ogImage = "/images/og-default.svg", ogType = "website", jsonLd } = Astro.props;
const site = Astro.site ?? new URL(Astro.url.origin);
const pageTitle = getPageTitle(locale, title);
const canonical = new URL(Astro.url.pathname, site);
const ogImageUrl = new URL(ogImage, site);
const pathWithoutLocale = Astro.url.pathname.replace(/^\/(zh-tw|en|ja|ko)/, "") || "/";
const alternates = alternatePaths ?? Object.fromEntries(locales.map((alternateLocale) => [
  alternateLocale,
  localizePath(alternateLocale, pathWithoutLocale)
])) as Partial<Record<Locale, string>>;
const organizationId = new URL("/#organization", site).href;
const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": organizationId,
  name: "TachiSuke",
  alternateName: ["達助日本生活", "Japan Life Assistant"],
  url: new URL("/", site).href,
  logo: new URL("/favicon.svg", site).href
};
const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": new URL("/#website", site).href,
  name: "TachiSuke",
  url: new URL("/", site).href,
  description: "A multilingual life decision assistant for living in Japan.",
  inLanguage: Object.values(htmlLangByLocale),
  publisher: { "@id": organizationId }
};
const jsonLdItems = [
  organizationJsonLd,
  websiteJsonLd,
  ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [])
];
const skipLinkLabel = getUiCopy(locale, "layout.skipMain");

function serializeJsonLd(item: JsonLdObject): string {
  return JSON.stringify(item).replaceAll("<", "\\u003c");
}
---

<!doctype html>
<html lang={htmlLangByLocale[locale]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f5f8f7" />
    <meta name="application-name" content="TachiSuke" />
    <meta name="apple-mobile-web-app-title" content="TachiSuke" />
    <meta name="format-detection" content="telephone=no" />
    {robots && <meta name="robots" content={robots} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="search" type="application/opensearchdescription+xml" title="TachiSuke Search" href={new URL("/opensearch.xml", site).href} />
    <link rel="alternate" type="application/rss+xml" title="TachiSuke RSS" href={new URL("/feed.xml", site).href} />
    <link rel="alternate" type="application/rss+xml" title={`TachiSuke ${locale} RSS`} href={new URL(localizePath(locale, "/feed.xml"), site).href} />
    <link rel="canonical" href={canonical.href} />
    {locales.map((alternateLocale) => alternates[alternateLocale] && (
      <link
        rel="alternate"
        hreflang={htmlLangByLocale[alternateLocale]}
        href={new URL(alternates[alternateLocale] ?? "/", site).href}
      />
    ))}
    {alternates.en && <link rel="alternate" hreflang="x-default" href={new URL(alternates.en, site).href} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:site_name" content="TachiSuke" />
    <meta property="og:image" content={ogImageUrl.href} />
    <meta property="og:image:alt" content="TachiSuke - Japan Life Assistant" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl.href} />
    {jsonLdItems.map((item) => <script is:inline type="application/ld+json" set:html={serializeJsonLd(item)} />)}
  </head>
  <body>
    <a class="skip-link" href="#main-content">{skipLinkLabel}</a>
    <Header locale={locale} currentPath={Astro.url.pathname} alternatePaths={alternates} />
    <main id="main-content" class="site-main" tabindex="-1">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
