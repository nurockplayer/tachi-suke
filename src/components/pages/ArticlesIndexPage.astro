---
import { getCollection } from "astro:content";
import BaseLayout from "@/components/layout/BaseLayout.astro";
import FavoriteButtonPlaceholder from "@/components/favorites/FavoriteButtonPlaceholder.astro";
import { formatDate } from "@/lib/content";
import { getArticleCategorySummaries, getArticleCategoryTitle } from "@/lib/content/article-categories";
import { localizePath, sectionCopy, type Locale } from "@/lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const title = sectionCopy[locale].articlesTitle;
const articles = (await getCollection("articles"))
  .filter((article) => article.data.locale === locale && !article.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const categories = await getArticleCategorySummaries(locale);
---

<BaseLayout locale={locale} title={title} description={`${title} | TachiSuke`}>
  <section class="page-hero">
    <div class="container">
      <h1>{title}</h1>
      <p>{locale === "zh-tw" ? "用比較、清單與實際提醒協助你做日本生活決策。" : locale === "en" ? "Practical comparisons, checklists, and notes for life decisions in Japan." : locale === "ja" ? "比較、チェックリスト、実用的な注意点で日本生活の判断を支えます。" : "비교, 체크리스트, 실용적인 메모로 일본 생활 결정을 돕습니다."}</p>
    </div>
  </section>
  <section class="section">
    <div class="container category-link-list" aria-label="Article categories">
      {categories.map((category) => (
        <a href={localizePath(locale, `/articles/category/${category.slug}`)}>
          <span>{getArticleCategoryTitle(locale, category.category)}</span>
          <strong>{category.count}</strong>
        </a>
      ))}
    </div>
  </section>
  <section class="section article-index-section">
    <div class="container article-list">
      {articles.map((article) => (
        <article class="article-row">
          <a href={localizePath(locale, `/articles/${article.data.slug}`)}>
            <span class="article-meta">{article.data.category} · {formatDate(article.data.publishedAt, locale)}</span>
            <h2>{article.data.title}</h2>
            <p>{article.data.description}</p>
          </a>
          <FavoriteButtonPlaceholder locale={locale} />
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
