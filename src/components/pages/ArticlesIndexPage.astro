---
import { getCollection } from "astro:content";
import BaseLayout from "@/components/layout/BaseLayout.astro";
import Breadcrumbs from "@/components/navigation/Breadcrumbs.astro";
import FavoriteButtonPlaceholder from "@/components/favorites/FavoriteButtonPlaceholder.astro";
import { formatDate } from "@/lib/content";
import { getArticleCategorySummaries, getArticleCategoryTitle } from "@/lib/content/article-categories";
import { getUiCopy, htmlLangByLocale, localizePath, sectionCopy, type Locale } from "@/lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const title = sectionCopy[locale].articlesTitle;
const articleCategoriesLabel = getUiCopy(locale, "layout.articleCategories");
const description = locale === "zh-tw"
  ? "用比較、清單與實際提醒協助你做日本生活決策。"
  : locale === "en"
    ? "Practical comparisons, checklists, and notes for life decisions in Japan."
    : locale === "ja"
      ? "比較、チェックリスト、実用的な注意点で日本生活の判断を支えます。"
      : "비교, 체크리스트, 실용적인 메모로 일본 생활 결정을 돕습니다.";
const articles = (await getCollection("articles"))
  .filter((article) => article.data.locale === locale && !article.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const categories = await getArticleCategorySummaries(locale);
const site = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = new URL(Astro.url.pathname, site).href;
const localeHomeUrl = new URL(localizePath(locale), site).href;
const breadcrumbItems = [
  { label: "TachiSuke", href: localizePath(locale) },
  { label: title }
];
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": `${canonicalUrl}#webpage`,
    name: title,
    description,
    url: canonicalUrl,
    inLanguage: htmlLangByLocale[locale],
    isPartOf: { "@id": new URL("/#website", site).href },
    publisher: { "@id": new URL("/#organization", site).href }
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "@id": `${canonicalUrl}#article-list`,
    name: title,
    description,
    numberOfItems: articles.length,
    itemListElement: articles.map((article, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: new URL(localizePath(locale, `/articles/${article.data.slug}`), site).href,
      name: article.data.title,
      description: article.data.description
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${canonicalUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "TachiSuke",
        item: localeHomeUrl
      },
      {
        "@type": "ListItem",
        position: 2,
        name: title,
        item: canonicalUrl
      }
    ]
  }
];
---

<BaseLayout locale={locale} title={title} description={description} jsonLd={jsonLd}>
  <section class="page-hero">
    <div class="container">
      <Breadcrumbs locale={locale} items={breadcrumbItems} />
      <h1>{title}</h1>
      <p>{description}</p>
    </div>
  </section>
  <section class="section">
    <div class="container category-link-list" aria-label={articleCategoriesLabel}>
      {categories.map((category) => (
        <a href={localizePath(locale, `/articles/category/${category.slug}`)}>
          <span>{getArticleCategoryTitle(locale, category.category)}</span>
          <strong>{category.count}</strong>
        </a>
      ))}
    </div>
  </section>
  <section class="section article-index-section">
    <div class="container article-list">
      {articles.map((article) => (
        <article class="article-row">
          <a href={localizePath(locale, `/articles/${article.data.slug}`)}>
            <span class="article-meta">{getArticleCategoryTitle(locale, article.data.category)} · {formatDate(article.data.publishedAt, locale)}</span>
            <h2>{article.data.title}</h2>
            <p>{article.data.description}</p>
          </a>
          <FavoriteButtonPlaceholder locale={locale} />
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
