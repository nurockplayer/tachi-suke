---
import { getCollection } from "astro:content";
import BaseLayout from "@/components/layout/BaseLayout.astro";
import MobilePlanCard from "@/components/mobile/MobilePlanCard.astro";
import { sectionCopy, type Locale } from "@/lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const title = sectionCopy[locale].mobileTitle;
const plans = await getCollection("mobile-plans");
---

<BaseLayout locale={locale} title={title} description={`${title} | TachiSuke`}>
  <section class="page-hero">
    <div class="container">
      <h1>{title}</h1>
      <p>{locale === "zh-tw" ? "用文件、付款方式、資料量、收訊與申請難度比較日本手機方案。" : locale === "en" ? "Compare Japanese mobile plans by documents, payment methods, data, coverage, and setup difficulty." : locale === "ja" ? "本人確認、支払い方法、データ容量、通信エリア、申し込みやすさで比較します。" : "서류, 결제 방법, 데이터, 통신 품질, 신청 난이도로 비교합니다."}</p>
    </div>
  </section>
  <section class="section">
    <div class="container grid grid-2">
      {plans.map((plan) => <MobilePlanCard plan={plan} />)}
    </div>
  </section>
</BaseLayout>
