---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import CategoryCard from "@/components/content/CategoryCard.astro";
import { localizePath, type Locale } from "@/lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = {
  "zh-tw": {
    title: "謝謝你的回報",
    description: "你的訊息已送出。站長會檢查內容並在需要時修正 TachiSuke 的公開資訊。",
    reviewTitle: "接下來會發生什麼",
    review:
      "站長會檢查你的回報，並在確認後修正錯字、壞掉的連結、過期資訊或補充說明。TachiSuke 可能會整理你的建議來改善公開內容，但不會公開你的 Email。",
    privacyTitle: "隱私提醒",
    privacy:
      "如果你留下 Email，它只會用於必要的追問與確認。請不要透過表單傳送敏感個資、證件號碼、帳號密碼或他人的個人資訊。",
    home: "回首頁",
    articles: "閱讀生活文章",
    editorial: "查看編輯政策"
  },
  en: {
    title: "Thanks for the report",
    description: "Your message has been sent. The site owner will review it and update public TachiSuke content when needed.",
    reviewTitle: "What happens next",
    review:
      "The site owner will review your report and may fix typos, broken links, outdated information, or missing context after checking it. TachiSuke may use your suggestion to improve public content, but your email will not be public.",
    privacyTitle: "Privacy note",
    privacy:
      "If you left an email, it is only used for necessary follow-up. Do not send sensitive personal information, ID numbers, passwords, account details, or other people's personal information through the form.",
    home: "Home",
    articles: "Read articles",
    editorial: "Editorial policy"
  },
  ja: {
    title: "ご連絡ありがとうございます",
    description: "メッセージを受け付けました。管理者が確認し、必要に応じて TachiSuke の公開情報を更新します。",
    reviewTitle: "この後の流れ",
    review:
      "管理者が内容を確認し、誤字、リンク切れ、古い情報、不足している説明を必要に応じて修正します。提案は公開内容の改善に使う場合がありますが、メールアドレスは公開されません。",
    privacyTitle: "プライバシーの注意",
    privacy:
      "メールを入力した場合でも、必要な確認連絡にのみ使います。機微な個人情報、証明書番号、パスワード、アカウント情報、他人の個人情報はフォームで送らないでください。",
    home: "ホームへ",
    articles: "生活記事を読む",
    editorial: "編集方針を見る"
  },
  ko: {
    title: "제보해 주셔서 감사합니다",
    description: "메시지가 전송되었습니다. 운영자가 확인한 뒤 필요한 경우 TachiSuke의 공개 정보를 업데이트합니다.",
    reviewTitle: "다음 절차",
    review:
      "운영자가 제보를 확인하고 오타, 깨진 링크, 오래된 정보, 부족한 설명을 필요에 따라 수정합니다. 제안은 공개 콘텐츠 개선에 활용될 수 있지만 이메일은 공개되지 않습니다.",
    privacyTitle: "개인정보 안내",
    privacy:
      "이메일을 남긴 경우 필요한 확인 연락에만 사용합니다. 민감한 개인정보, 신분증 번호, 비밀번호, 계정 정보, 타인의 개인정보를 폼으로 보내지 마세요.",
    home: "홈으로",
    articles: "생활 글 읽기",
    editorial: "편집 정책 보기"
  }
}[locale];
---

<BaseLayout locale={locale} title={copy.title} description={copy.description}>
  <section class="page-hero">
    <div class="container">
      <h1>{copy.title}</h1>
      <p>{copy.description}</p>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-2">
      <article class="notice">
        <h2>{copy.reviewTitle}</h2>
        <p>{copy.review}</p>
      </article>
      <article class="notice">
        <h2>{copy.privacyTitle}</h2>
        <p>{copy.privacy}</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-3">
      <CategoryCard href={localizePath(locale)} title={copy.home} description={copy.description} />
      <CategoryCard href={localizePath(locale, "/articles")} title={copy.articles} description={copy.review} />
      <CategoryCard href={localizePath(locale, "/editorial-policy")} title={copy.editorial} description={copy.privacy} />
    </div>
  </section>
</BaseLayout>
