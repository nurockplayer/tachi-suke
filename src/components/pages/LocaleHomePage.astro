---
import { getCollection } from "astro:content";
import BaseLayout from "@/components/layout/BaseLayout.astro";
import CategoryCard from "@/components/content/CategoryCard.astro";
import PlaceCard from "@/components/places/PlaceCard.astro";
import MobilePlanCard from "@/components/mobile/MobilePlanCard.astro";
import FavoriteButtonPlaceholder from "@/components/favorites/FavoriteButtonPlaceholder.astro";
import { categoryEntries, formatDate } from "@/lib/content";
import { getArticleCategoryTitle } from "@/lib/content/article-categories";
import { homeCopy, htmlLangByLocale, localizePath, type Locale } from "@/lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = homeCopy[locale];
const articles = (await getCollection("articles"))
  .filter((article) => article.data.locale === locale && !article.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 4);
const places = (await getCollection("places")).filter((place) => place.data.status === "published").slice(0, 3);
const mobilePlans = (await getCollection("mobile-plans")).slice(0, 2);
const mobileEntryLinkLabel = {
  "zh-tw": "查看手機方案",
  en: "View",
  ja: "携帯プランを見る",
  ko: "요금제 보기"
}[locale];
const startHereTitle = {
  "zh-tw": "熱門入口",
  en: "Start here",
  ja: "まず見るところ",
  ko: "먼저 볼 곳"
}[locale];
const firstWeekArticlePath = {
  "zh-tw": "/articles/newcomer-first-week-japan-setup",
  en: "/articles/first-week-japan-setup",
  ja: "/articles/japan-life-first-week-setup-ja",
  ko: "/articles/japan-life-first-week-setup-ko"
}[locale];
const startLinks = [
  {
    href: firstWeekArticlePath,
    title: {
      "zh-tw": "剛到日本第一週",
      en: "First week setup",
      ja: "最初の1週間",
      ko: "일본 생활 첫 주"
    },
    description: {
      "zh-tw": "先排手機、住址、交通、買物與可安心吃飯的地方。",
      en: "Order mobile, address, commuting, shopping, and safe meal spots.",
      ja: "携帯、住所、交通、買い物、安心できる食事場所の順番を整理します。",
      ko: "휴대폰, 주소, 교통, 장보기, 편한 식사 장소의 순서를 정리합니다."
    }
  },
  {
    href: "/mobile",
    title: {
      "zh-tw": "比較手機門號",
      en: "Compare mobile plans",
      ja: "携帯プランを比較",
      ko: "휴대폰 요금제 비교"
    },
    description: {
      "zh-tw": "先看文件、付款方式、資料量、通話與收訊。",
      en: "Start with documents, payment, data, calls, and coverage.",
      ja: "本人確認、支払い、データ、通話、通信エリアから確認します。",
      ko: "본인 확인, 결제, 데이터, 통화, 통신 품질부터 확인합니다."
    }
  },
  {
    href: "/areas",
    title: {
      "zh-tw": "選生活圈",
      en: "Choose an area",
      ja: "住むエリアを考える",
      ko: "생활권 고르기"
    },
    description: {
      "zh-tw": "用租金感、通勤、安靜度與生活機能比較東京區域。",
      en: "Compare Tokyo areas by rent feel, commute, quietness, and daily convenience.",
      ja: "家賃感、通勤、静かさ、生活利便性で東京のエリアを見ます。",
      ko: "월세감, 통근, 조용함, 생활 편의성으로 도쿄 지역을 봅니다."
    }
  },
  {
    href: "/places",
    title: {
      "zh-tw": "找實用店家",
      en: "Find useful places",
      ja: "使いやすいお店を探す",
      ko: "유용한 장소 찾기"
    },
    description: {
      "zh-tw": "先從單人友善、禁菸、付款方式清楚的地方開始。",
      en: "Start with places that are solo-friendly, clear about smoking, and easy to pay at.",
      ja: "一人利用、禁煙、支払い方法がわかりやすい場所から始めます。",
      ko: "혼자 이용, 금연, 결제 방식이 알기 쉬운 곳부터 봅니다."
    }
  },
  {
    href: "/submit-place",
    title: {
      "zh-tw": "推薦實用店家",
      en: "Submit a useful place",
      ja: "おすすめを投稿",
      ko: "유용한 장소 추천"
    },
    description: {
      "zh-tw": "投稿不會直接公開，會先審核與整理。",
      en: "Submissions are reviewed and normalized before publication.",
      ja: "投稿は直接公開されず、確認と整理の後に掲載されます。",
      ko: "추천은 바로 공개되지 않고 검토와 정리 후 게시됩니다."
    }
  },
  {
    href: "/tools/ward-office-moving-in-checklist",
    title: {
      "zh-tw": "區役所手續清單",
      en: "Ward office checklist",
      ja: "役所手続きチェック",
      ko: "구청 절차 체크"
    },
    description: {
      "zh-tw": "搬入後先確認地址、在留卡、保險、年金與 My Number。",
      en: "Check address, residence card, insurance, pension, and My Number after moving in.",
      ja: "転入後の住所、在留カード、保険、年金、マイナンバーを確認します。",
      ko: "전입 후 주소, 재류카드, 보험, 연금, 마이넘버를 확인합니다."
    }
  }
];
const site = Astro.site ?? new URL(Astro.url.origin);
const homepagePath = localizePath(locale, "/");
const homepageUrl = new URL(homepagePath, site).href;
const startHereItemListId = new URL(`${homepagePath}#start-here`, site).href;
const homeJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": new URL(`${homepagePath}#webpage`, site).href,
    url: homepageUrl,
    name: `TachiSuke - ${copy.title}`,
    description: copy.description,
    inLanguage: htmlLangByLocale[locale],
    isPartOf: { "@id": new URL("/#website", site).href },
    publisher: { "@id": new URL("/#organization", site).href },
    mainEntity: { "@id": startHereItemListId }
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "@id": startHereItemListId,
    name: startHereTitle,
    description: copy.decisionNote,
    inLanguage: htmlLangByLocale[locale],
    itemListElement: startLinks.map((entry, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: entry.title[locale],
      description: entry.description[locale],
      url: new URL(localizePath(locale, entry.href), site).href
    }))
  }
];
---

<BaseLayout locale={locale} title="Japan Life Assistant" description={copy.description} jsonLd={homeJsonLd}>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <h1>{copy.title}</h1>
        <p>{copy.description}</p>
        <div class="hero-actions">
          <a class="button-link" href={localizePath(locale, "/articles")}>{copy.primaryCta}</a>
          <a class="button-secondary" href={localizePath(locale, "/submit-place")}>{copy.secondaryCta}</a>
        </div>
        <span class="decision-note">{copy.decisionNote}</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{copy.categories}</h2>
        </div>
      </div>
      <div class="grid grid-4">
        {categoryEntries.map((entry) => (
          <CategoryCard
            href={localizePath(locale, entry.href)}
            title={entry.title[locale]}
            description={entry.description[locale]}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{startHereTitle}</h2>
          <p>{locale === "zh-tw" ? "不知道從哪裡開始時，先從這幾個入口建立生活決策順序。" : locale === "en" ? "If you are not sure where to start, use these entry points to build your decision order." : locale === "ja" ? "どこから始めるか迷うときは、この入口から生活の判断順を整理できます。" : "어디서 시작할지 모르겠다면 이 입구에서 생활 결정 순서를 정리하세요."}</p>
        </div>
      </div>
      <div class="grid grid-3">
        {startLinks.map((entry) => (
          <CategoryCard
            href={localizePath(locale, entry.href)}
            title={entry.title[locale]}
            description={entry.description[locale]}
          />
        ))}
        <CategoryCard
          href={localizePath(locale, "/account/favorites")}
          title={locale === "zh-tw" ? "收藏入口 placeholder" : locale === "en" ? "Favorites placeholder" : locale === "ja" ? "保存機能 placeholder" : "저장 기능 placeholder"}
          description={locale === "zh-tw" ? "未來登入後可以查看收藏文章、店家、手機方案、地區與工具。" : locale === "en" ? "Later, logged-in users can view saved articles, places, mobile plans, areas, and tools." : locale === "ja" ? "将来ログイン後に保存した記事、お店、携帯プラン、エリア、ツールを確認できます。" : "나중에 로그인하면 저장한 글, 장소, 휴대폰 요금제, 지역, 도구를 볼 수 있습니다."}
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{locale === "zh-tw" ? "手機門號入口" : locale === "en" ? "Mobile plan entry" : locale === "ja" ? "携帯プラン入口" : "휴대폰 요금제 입구"}</h2>
          <p>{locale === "zh-tw" ? "先用文件、付款方式、資料量與收訊需求排除不適合的方案。" : locale === "en" ? "Start by filtering plans by documents, payment method, data needs, and coverage." : locale === "ja" ? "本人確認、支払い方法、データ容量、通信エリアから候補を絞ります。" : "서류, 결제 방법, 데이터 사용량, 통신 품질로 후보를 좁힙니다."}</p>
        </div>
        <a class="text-link" href={localizePath(locale, "/mobile")}>{mobileEntryLinkLabel}</a>
      </div>
      <div class="grid grid-2">
        {mobilePlans.map((plan) => <MobilePlanCard plan={plan} locale={locale} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-2">
        <article class="notice">
          <h2>{locale === "zh-tw" ? "地區生活圈入口" : locale === "en" ? "Area guide entry" : locale === "ja" ? "エリア生活ガイド" : "지역 생활권 입구"}</h2>
          <p>{locale === "zh-tw" ? "未來會用租金、交通、生活機能、安靜度與適合族群整理城市與街區。" : locale === "en" ? "Future guides will compare rent, commute, daily convenience, quietness, and fit." : locale === "ja" ? "家賃、通勤、生活利便性、静かさ、向いている人でエリアを整理します。" : "월세, 통근, 생활 편의성, 조용함, 어울리는 사람을 기준으로 정리합니다."}</p>
          <div class="inline-actions">
            <a class="button-secondary" href={localizePath(locale, "/areas")}>View</a>
          </div>
        </article>
        <article class="notice">
          <h2>{locale === "zh-tw" ? "投稿推薦店家入口" : locale === "en" ? "Submit a useful place" : locale === "ja" ? "おすすめのお店を投稿" : "유용한 장소 추천"}</h2>
          <p>{locale === "zh-tw" ? "推薦不會直接公開，站長會審核並整理資訊後再發布。" : locale === "en" ? "Submissions are reviewed and normalized before publication." : locale === "ja" ? "投稿は直接公開されず、確認と整理の後に掲載されます。" : "추천은 바로 공개되지 않으며 검토와 정리 후 게시됩니다."}</p>
          <div class="inline-actions">
            <a class="button-secondary" href={localizePath(locale, "/submit-place")}>{copy.secondaryCta}</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{locale === "zh-tw" ? "店家推薦入口" : locale === "en" ? "Useful places" : locale === "ja" ? "おすすめのお店" : "유용한 장소"}</h2>
          <p>{locale === "zh-tw" ? "先收錄適合日常生活、單人友善、外國居民容易使用的店家。" : locale === "en" ? "Starting with practical, everyday, resident-friendly places." : locale === "ja" ? "日常的に使いやすく、一人でも入りやすいお店から整理します。" : "일상적으로 쓰기 좋고 혼자서도 이용하기 쉬운 장소부터 정리합니다."}</p>
        </div>
        <a class="text-link" href={localizePath(locale, "/places")}>View</a>
      </div>
      <div class="grid grid-3">
        {places.map((place) => <PlaceCard place={place} locale={locale} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="notice">
        <h2>{locale === "zh-tw" ? "未來收藏功能入口 placeholder" : locale === "en" ? "Future favorites placeholder" : locale === "ja" ? "保存機能 placeholder" : "저장 기능 placeholder"}</h2>
        <p>{locale === "zh-tw" ? "未來登入後可以收藏文章、店家、手機方案、地區與工具。" : locale === "en" ? "Later, logged-in users will save articles, places, mobile plans, areas, and tools." : locale === "ja" ? "将来ログイン後に記事、お店、携帯プラン、エリア、ツールを保存できます。" : "이후 로그인하면 글, 장소, 휴대폰 요금제, 지역, 도구를 저장할 수 있습니다."}</p>
        <div class="inline-actions">
          <FavoriteButtonPlaceholder locale={locale} />
          <a class="button-secondary" href={localizePath(locale, "/account/favorites")}>View</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{copy.latest}</h2>
        </div>
        <a class="text-link" href={localizePath(locale, "/articles")}>View</a>
      </div>
      <div class="article-list">
        {articles.map((article) => (
          <a class="article-row" href={localizePath(locale, `/articles/${article.data.slug}`)}>
            <span class="article-meta">{getArticleCategoryTitle(locale, article.data.category)} · {formatDate(article.data.publishedAt, locale)}</span>
            <h3>{article.data.title}</h3>
            <p>{article.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
