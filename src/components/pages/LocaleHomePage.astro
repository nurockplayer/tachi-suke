---
import { getCollection } from "astro:content";
import BaseLayout from "@/components/layout/BaseLayout.astro";
import CategoryCard from "@/components/content/CategoryCard.astro";
import PlaceCard from "@/components/places/PlaceCard.astro";
import MobilePlanCard from "@/components/mobile/MobilePlanCard.astro";
import FavoriteButtonPlaceholder from "@/components/favorites/FavoriteButtonPlaceholder.astro";
import { categoryEntries, formatDate } from "@/lib/content";
import { homeCopy, localizePath, type Locale } from "@/lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = homeCopy[locale];
const articles = (await getCollection("articles"))
  .filter((article) => article.data.locale === locale && !article.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 4);
const places = (await getCollection("places")).filter((place) => place.data.status === "published").slice(0, 3);
const mobilePlans = (await getCollection("mobile-plans")).slice(0, 2);
---

<BaseLayout locale={locale} title="Japan Life Assistant" description={copy.description}>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <h1>{copy.title}</h1>
        <p>{copy.description}</p>
        <div class="hero-actions">
          <a class="button-link" href={localizePath(locale, "/articles")}>{copy.primaryCta}</a>
          <a class="button-secondary" href={localizePath(locale, "/submit-place")}>{copy.secondaryCta}</a>
        </div>
        <span class="decision-note">{copy.decisionNote}</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{copy.categories}</h2>
        </div>
      </div>
      <div class="grid grid-4">
        {categoryEntries.map((entry) => (
          <CategoryCard
            href={localizePath(locale, entry.href)}
            title={entry.title[locale]}
            description={entry.description[locale]}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{locale === "zh-tw" ? "手機門號入口" : locale === "en" ? "Mobile plan entry" : locale === "ja" ? "携帯プラン入口" : "휴대폰 요금제 입구"}</h2>
          <p>{locale === "zh-tw" ? "先用文件、付款方式、資料量與收訊需求排除不適合的方案。" : locale === "en" ? "Start by filtering plans by documents, payment method, data needs, and coverage." : locale === "ja" ? "本人確認、支払い方法、データ容量、通信エリアから候補を絞ります。" : "서류, 결제 방법, 데이터 사용량, 통신 품질로 후보를 좁힙니다."}</p>
        </div>
        <a class="text-link" href={localizePath(locale, "/mobile")}>View</a>
      </div>
      <div class="grid grid-2">
        {mobilePlans.map((plan) => <MobilePlanCard plan={plan} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-2">
        <article class="notice">
          <h2>{locale === "zh-tw" ? "地區生活圈入口" : locale === "en" ? "Area guide entry" : locale === "ja" ? "エリア生活ガイド" : "지역 생활권 입구"}</h2>
          <p>{locale === "zh-tw" ? "未來會用租金、交通、生活機能、安靜度與適合族群整理城市與街區。" : locale === "en" ? "Future guides will compare rent, commute, daily convenience, quietness, and fit." : locale === "ja" ? "家賃、通勤、生活利便性、静かさ、向いている人でエリアを整理します。" : "월세, 통근, 생활 편의성, 조용함, 어울리는 사람을 기준으로 정리합니다."}</p>
          <div class="inline-actions">
            <a class="button-secondary" href={localizePath(locale, "/areas")}>View</a>
          </div>
        </article>
        <article class="notice">
          <h2>{locale === "zh-tw" ? "投稿推薦店家入口" : locale === "en" ? "Submit a useful place" : locale === "ja" ? "おすすめのお店を投稿" : "유용한 장소 추천"}</h2>
          <p>{locale === "zh-tw" ? "推薦不會直接公開，站長會審核並整理資訊後再發布。" : locale === "en" ? "Submissions are reviewed and normalized before publication." : locale === "ja" ? "投稿は直接公開されず、確認と整理の後に掲載されます。" : "추천은 바로 공개되지 않으며 검토와 정리 후 게시됩니다."}</p>
          <div class="inline-actions">
            <a class="button-secondary" href={localizePath(locale, "/submit-place")}>{copy.secondaryCta}</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{locale === "zh-tw" ? "店家推薦入口" : locale === "en" ? "Useful places" : locale === "ja" ? "おすすめのお店" : "유용한 장소"}</h2>
          <p>{locale === "zh-tw" ? "先收錄適合日常生活、單人友善、外國居民容易使用的店家。" : locale === "en" ? "Starting with practical, everyday, resident-friendly places." : locale === "ja" ? "日常的に使いやすく、一人でも入りやすいお店から整理します。" : "일상적으로 쓰기 좋고 혼자서도 이용하기 쉬운 장소부터 정리합니다."}</p>
        </div>
        <a class="text-link" href={localizePath(locale, "/places")}>View</a>
      </div>
      <div class="grid grid-3">
        {places.map((place) => <PlaceCard place={place} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="notice">
        <h2>{locale === "zh-tw" ? "未來收藏功能入口 placeholder" : locale === "en" ? "Future favorites placeholder" : locale === "ja" ? "保存機能 placeholder" : "저장 기능 placeholder"}</h2>
        <p>{locale === "zh-tw" ? "未來登入後可以收藏文章、店家、手機方案、地區與工具。" : locale === "en" ? "Later, logged-in users will save articles, places, mobile plans, areas, and tools." : locale === "ja" ? "将来ログイン後に記事、お店、携帯プラン、エリア、ツールを保存できます。" : "이후 로그인하면 글, 장소, 휴대폰 요금제, 지역, 도구를 저장할 수 있습니다."}</p>
        <div class="inline-actions">
          <FavoriteButtonPlaceholder locale={locale} />
          <a class="button-secondary" href={localizePath(locale, "/account/favorites")}>View</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{copy.latest}</h2>
        </div>
        <a class="text-link" href={localizePath(locale, "/articles")}>View</a>
      </div>
      <div class="article-list">
        {articles.map((article) => (
          <a class="article-row" href={localizePath(locale, `/articles/${article.data.slug}`)}>
            <span class="article-meta">{article.data.category} · {formatDate(article.data.publishedAt, locale)}</span>
            <h3>{article.data.title}</h3>
            <p>{article.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
