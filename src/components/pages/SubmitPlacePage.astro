---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import { localeNames, locales, localizePath, sectionCopy, type Locale } from "@/lib/i18n";
import { japaneseDifficultyLabels, nonSmokingStatusLabels, soloFriendlyLabels } from "@/lib/places";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const title = sectionCopy[locale].submitTitle;
const formEndpoint = import.meta.env.PUBLIC_SUBMIT_PLACE_FORM_ENDPOINT?.trim() ?? "";
const thanksUrl = new URL(localizePath(locale, "/submit-place/thanks"), Astro.site ?? new URL(Astro.url.origin)).href;
const labels = {
  "zh-tw": {
    intro: formEndpoint ? "你可以推薦日常生活中實用的店家。投稿會先人工審核，不會直接公開。" : "投稿表單目前是 preview mode。站長設定外部表單 endpoint 後才會開放送出。",
    review: "投稿不會直接公開，內容會先人工審核。站長可能會整理、改寫、標準化內容後發布。Email 不會公開。不要填寫他人個資或敏感資訊；營業時間、價格、禁菸規則等資訊發布前仍需確認。",
    preview: "投稿功能準備中：目前尚未設定外部表單 endpoint，所以表單不會送出。",
    submit: "送出推薦",
    mapsHelp: "Google Maps URL 最重要，請優先提供正確連結。",
    privacyHelp: "不要填寫他人個資或敏感資訊。",
    emailHelp: "Email 選填且不會公開，只會用於必要時聯絡確認。"
  },
  en: {
    intro: formEndpoint ? "Recommend a useful everyday place. Submissions are manually reviewed and will not publish directly." : "This form is in preview mode. Submissions open after the site owner configures an external form endpoint.",
    review: "Submissions are not published directly. Content is manually reviewed first. The site owner may edit, rewrite, and normalize information before publishing. Email will not be public. Do not submit other people's personal or sensitive information; hours, prices, and smoking rules still need confirmation before publication.",
    preview: "Submission is not active yet: no external form endpoint is configured, so this form will not send.",
    submit: "Submit recommendation",
    mapsHelp: "Google Maps URL is the most important field. Please provide the exact place link.",
    privacyHelp: "Do not enter other people's personal or sensitive information.",
    emailHelp: "Email is optional and private. It is only for follow-up if needed."
  },
  ja: {
    intro: formEndpoint ? "日常生活で役立つお店を推薦できます。投稿は人の確認を経て、直接公開されません。" : "このフォームは preview mode です。外部フォーム endpoint が設定されるまで送信できません。",
    review: "投稿は直接公開されず、先に人の確認が入ります。管理者が内容を整理、書き直し、標準化して掲載する場合があります。メールアドレスは公開されません。他人の個人情報や機微な情報を書かないでください。営業時間、価格、禁煙ルールは掲載前にも確認が必要です。",
    preview: "投稿機能は準備中です。外部フォーム endpoint が未設定のため、このフォームは送信されません。",
    submit: "おすすめを送信",
    mapsHelp: "Google Maps URL が最も重要です。正確なお店のリンクを入力してください。",
    privacyHelp: "他人の個人情報や機微な情報を書かないでください。",
    emailHelp: "メールは任意で、公開されません。必要な確認連絡にのみ使います。"
  },
  ko: {
    intro: formEndpoint ? "일상생활에 유용한 장소를 추천할 수 있습니다. 추천은 사람이 검토하며 바로 공개되지 않습니다." : "이 폼은 preview mode입니다. 외부 폼 endpoint가 설정된 뒤에만 제출할 수 있습니다.",
    review: "추천은 바로 공개되지 않고 먼저 사람이 검토합니다. 운영자가 내용을 정리, 수정, 표준화한 뒤 게시할 수 있습니다. 이메일은 공개되지 않습니다. 타인의 개인정보나 민감한 정보를 입력하지 마세요. 영업시간, 가격, 금연 규칙은 게시 전에도 확인이 필요합니다.",
    preview: "추천 기능은 준비 중입니다. 외부 폼 endpoint가 설정되지 않아 이 폼은 전송되지 않습니다.",
    submit: "추천 보내기",
    mapsHelp: "Google Maps URL이 가장 중요합니다. 정확한 장소 링크를 입력해 주세요.",
    privacyHelp: "타인의 개인정보나 민감한 정보를 입력하지 마세요.",
    emailHelp: "이메일은 선택 사항이며 공개되지 않습니다. 필요한 확인 연락에만 사용합니다."
  }
}[locale];

const field = {
  language: locale === "zh-tw" ? "投稿語言" : locale === "en" ? "Submission language" : locale === "ja" ? "投稿言語" : "추천 언어",
  name: locale === "zh-tw" ? "店家名稱" : locale === "en" ? "Place name" : locale === "ja" ? "お店の名前" : "장소 이름",
  category: locale === "zh-tw" ? "分類" : locale === "en" ? "Category" : locale === "ja" ? "カテゴリ" : "카테고리",
  prefecture: locale === "zh-tw" ? "都道府縣" : locale === "en" ? "Prefecture" : locale === "ja" ? "都道府県" : "도도부현",
  city: locale === "zh-tw" ? "城市" : locale === "en" ? "City" : locale === "ja" ? "市区町村" : "도시",
  area: locale === "zh-tw" ? "地區" : locale === "en" ? "Area" : locale === "ja" ? "エリア" : "지역",
  station: locale === "zh-tw" ? "最近車站" : locale === "en" ? "Nearest station" : locale === "ja" ? "最寄り駅" : "가까운 역",
  maps: locale === "zh-tw" ? "Google Maps URL" : "Google Maps URL",
  official: locale === "zh-tw" ? "官方網站 URL" : locale === "en" ? "Official URL" : locale === "ja" ? "公式サイト URL" : "공식 URL",
  reason: locale === "zh-tw" ? "推薦理由" : locale === "en" ? "Recommendation reason" : locale === "ja" ? "おすすめ理由" : "추천 이유",
  price: locale === "zh-tw" ? "價格帶" : locale === "en" ? "Price range" : locale === "ja" ? "価格帯" : "가격대",
  solo: locale === "zh-tw" ? "單人友善程度" : locale === "en" ? "Solo-friendly status" : locale === "ja" ? "一人利用しやすさ" : "혼자 이용하기",
  smoke: locale === "zh-tw" ? "禁菸狀態" : locale === "en" ? "Non-smoking status" : locale === "ja" ? "禁煙状況" : "금연 상태",
  japanese: locale === "zh-tw" ? "日文難度" : locale === "en" ? "Japanese difficulty" : locale === "ja" ? "日本語の難しさ" : "일본어 난이도",
  payment: locale === "zh-tw" ? "付款方式" : locale === "en" ? "Payment methods" : locale === "ja" ? "支払い方法" : "결제 방법",
  nickname: locale === "zh-tw" ? "投稿者暱稱" : locale === "en" ? "Submitter nickname" : locale === "ja" ? "投稿者ニックネーム" : "추천자 닉네임",
  email: locale === "zh-tw" ? "Email（選填）" : locale === "en" ? "Email (optional)" : locale === "ja" ? "メール（任意）" : "이메일 (선택)"
};
---

<BaseLayout locale={locale} title={title} description={labels.intro}>
  <section class="page-hero">
    <div class="container">
      <h1>{title}</h1>
      <p>{labels.intro}</p>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-2">
      <aside class="notice">
        <h2>{locale === "zh-tw" ? "投稿前請確認" : locale === "en" ? "Before submitting" : locale === "ja" ? "投稿前の確認" : "추천 전 확인"}</h2>
        <p>{labels.review}</p>
        {!formEndpoint && <p class="help-text">{labels.preview}</p>}
      </aside>
      <form class="form-panel" aria-label={title} method="POST" action={formEndpoint}>
        <input type="hidden" name="formName" value="submit-place" />
        <input type="hidden" name="source" value="tachi-suke" />
        <input type="hidden" name="locale" value={locale} />
        <input type="hidden" name="moderationRequired" value="true" />
        <input type="hidden" name="publishDirectly" value="false" />
        <input type="hidden" name="redirectUrl" value={thanksUrl} />
        <div class="honeypot-field" aria-hidden="true">
          <label for="website">Website</label>
          <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
        </div>
        <div class="form-grid">
          <div class="field">
            <label for="submission-language">{field.language}</label>
            <select id="submission-language" name="submissionLanguage" required>
              {locales.map((optionLocale) => (
                <option value={optionLocale} selected={optionLocale === locale}>{localeNames[optionLocale]}</option>
              ))}
            </select>
          </div>
          <div class="field">
            <label for="place-name">{field.name}</label>
            <input id="place-name" name="placeName" type="text" required />
          </div>
          <div class="field">
            <label for="category">{field.category}</label>
            <input id="category" name="category" type="text" required />
          </div>
          <div class="field">
            <label for="prefecture">{field.prefecture}</label>
            <input id="prefecture" name="prefecture" type="text" required />
          </div>
          <div class="field">
            <label for="city">{field.city}</label>
            <input id="city" name="city" type="text" required />
          </div>
          <div class="field">
            <label for="area">{field.area}</label>
            <input id="area" name="area" type="text" />
          </div>
          <div class="field">
            <label for="station">{field.station}</label>
            <input id="station" name="station" type="text" />
          </div>
          <div class="field">
            <label for="maps">{field.maps}</label>
            <input id="maps" name="googleMapUrl" type="url" aria-describedby="maps-help" required />
            <span class="help-text" id="maps-help">{labels.mapsHelp}</span>
          </div>
          <div class="field">
            <label for="official">{field.official}</label>
            <input id="official" name="officialUrl" type="url" />
          </div>
          <div class="field">
            <label for="price">{field.price}</label>
            <input id="price" name="priceRange" type="text" />
          </div>
          <div class="field">
            <label for="solo">{field.solo}</label>
            <select id="solo" name="soloFriendly">
              <option value="unknown">{soloFriendlyLabels[locale].unknown}</option>
              <option value="yes">{soloFriendlyLabels[locale].yes}</option>
              <option value="maybe">{soloFriendlyLabels[locale].maybe}</option>
              <option value="no">{soloFriendlyLabels[locale].no}</option>
            </select>
          </div>
          <div class="field">
            <label for="smoke">{field.smoke}</label>
            <select id="smoke" name="nonSmokingStatus">
              <option value="unknown">{nonSmokingStatusLabels[locale].unknown}</option>
              <option value="confirmed_non_smoking">{nonSmokingStatusLabels[locale].confirmed_non_smoking}</option>
              <option value="separated_smoking_area">{nonSmokingStatusLabels[locale].separated_smoking_area}</option>
              <option value="smoking_allowed">{nonSmokingStatusLabels[locale].smoking_allowed}</option>
            </select>
          </div>
          <div class="field">
            <label for="japanese">{field.japanese}</label>
            <select id="japanese" name="japaneseDifficulty">
              <option value="unknown">{japaneseDifficultyLabels[locale].unknown}</option>
              <option value="easy">{japaneseDifficultyLabels[locale].easy}</option>
              <option value="normal">{japaneseDifficultyLabels[locale].normal}</option>
              <option value="hard">{japaneseDifficultyLabels[locale].hard}</option>
            </select>
          </div>
          <div class="field">
            <label for="payment">{field.payment}</label>
            <input id="payment" name="paymentMethods" type="text" />
          </div>
          <div class="field">
            <label for="nickname">{field.nickname}</label>
            <input id="nickname" name="submitterNickname" type="text" />
          </div>
          <div class="field">
            <label for="email">{field.email}</label>
            <input id="email" name="submitterEmail" type="email" aria-describedby="email-help" />
            <span class="help-text" id="email-help">{labels.emailHelp}</span>
          </div>
          <div class="field field-full">
            <label for="reason">{field.reason}</label>
            <textarea id="reason" name="recommendationReason" required></textarea>
            <span class="help-text">{labels.privacyHelp}</span>
          </div>
        </div>
        <div class="inline-actions">
          <button class={`button-link ${formEndpoint ? "" : "submit-disabled"}`} type="submit" disabled={!formEndpoint}>{labels.submit}</button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>
