---
import { getCollection } from "astro:content";
import BaseLayout from "@/components/layout/BaseLayout.astro";
import CategoryCard from "@/components/content/CategoryCard.astro";
import { localizePath, sectionCopy, type Locale } from "@/lib/i18n";

interface Props {
  locale: Locale;
  section: "areas" | "tools";
}

const { locale, section } = Astro.props;
const isAreas = section === "areas";
const title = isAreas ? sectionCopy[locale].areasTitle : sectionCopy[locale].toolsTitle;
const description = isAreas
  ? {
      "zh-tw": "用租金感、交通、生活機能、安靜度與適合族群比較東京生活圈，先排除不適合的地區。",
      en: "Compare Tokyo neighborhoods by rent feel, commute, daily convenience, quietness, and fit.",
      ja: "東京のエリアを家賃感、通勤、生活利便性、静かさ、向いている人で比較します。",
      ko: "도쿄 지역을 월세감, 통근, 생활 편의성, 조용함, 적합한 사람 기준으로 비교합니다."
    }[locale]
  : {
      "zh-tw": "未來會提供搬家清單、手機方案比較、租屋費用試算與行政流程工具。",
      en: "Future tools will include moving checklists, mobile comparisons, rent cost calculators, and procedure guides.",
      ja: "引っ越しチェックリスト、携帯比較、賃貸費用計算、手続きガイドを追加予定です。",
      ko: "이사 체크리스트, 휴대폰 비교, 임대 비용 계산, 행정 절차 도구를 추가할 예정입니다."
    }[locale];
const areas = isAreas ? await getCollection("areas") : [];
const areaDisplayNames = {
  ikebukuro: "Ikebukuro",
  itabashi: "Itabashi",
  akabane: "Akabane",
  "kagurazaka-edogawabashi": "Kagurazaka / Edogawabashi"
};
const areaLabels = {
  "zh-tw": {
    stations: "主要車站",
    rent: "租金感",
    food: "生活/外食",
    commute: "交通",
    quietness: "安靜度",
    fit: "適合",
    warnings: "注意"
  },
  en: {
    stations: "Stations",
    rent: "Rent feel",
    food: "Food/life",
    commute: "Commute",
    quietness: "Quietness",
    fit: "Good for",
    warnings: "Watchouts"
  },
  ja: {
    stations: "主な駅",
    rent: "家賃感",
    food: "生活/外食",
    commute: "交通",
    quietness: "静かさ",
    fit: "向いている人",
    warnings: "注意点"
  },
  ko: {
    stations: "주요 역",
    rent: "월세감",
    food: "생활/외식",
    commute: "교통",
    quietness: "조용함",
    fit: "추천 대상",
    warnings: "주의"
  }
}[locale];
---

<BaseLayout locale={locale} title={title} description={description}>
  <section class="page-hero">
    <div class="container">
      <h1>{title}</h1>
      <p>{description}</p>
    </div>
  </section>
  {isAreas && (
    <section class="section">
      <div class="container section-header">
        <div>
          <h2>{locale === "zh-tw" ? "東京生活圈範例" : locale === "en" ? "Tokyo area samples" : locale === "ja" ? "東京エリア例" : "도쿄 지역 예시"}</h2>
          <p>{locale === "zh-tw" ? "這些不是觀光推薦，而是用來判斷生活成本、通勤與日常便利性的起點。" : locale === "en" ? "These are not sightseeing picks. They are starting points for judging cost, commute, and daily convenience." : locale === "ja" ? "観光ではなく、生活費、通勤、日常利便性を判断するための入口です。" : "관광 추천이 아니라 생활비, 통근, 일상 편의성을 판단하기 위한 시작점입니다."}</p>
        </div>
      </div>
      <div class="container grid grid-2">
        {areas.map((area) => (
          <article class="notice area-card">
            <h2>{areaDisplayNames[area.data.slug as keyof typeof areaDisplayNames] ?? area.data.stations[0] ?? area.data.city}</h2>
            <p>{area.data.prefecture} · {area.data.stations.join(", ")}</p>
            <dl class="detail-list compact-list">
              <dt>{areaLabels.rent}</dt>
              <dd>{area.data.rentLevel}</dd>
              <dt>{areaLabels.food}</dt>
              <dd>{area.data.foodLevel}</dd>
              <dt>{areaLabels.commute}</dt>
              <dd>{area.data.commuteConvenience}</dd>
              <dt>{areaLabels.quietness}</dt>
              <dd>{area.data.quietness}</dd>
            </dl>
            <div class="content-stack">
              <p><strong>{areaLabels.fit}:</strong> {area.data.recommendedFor.join(", ")}</p>
              <p><strong>{areaLabels.warnings}:</strong> {area.data.warnings.join(" ")}</p>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}
  <section class="section">
    <div class="container grid grid-2">
      <CategoryCard
        href={localizePath(locale, isAreas ? "/articles" : "/mobile")}
        title={isAreas ? (locale === "zh-tw" ? "先看生活文章" : locale === "en" ? "Start with articles" : locale === "ja" ? "まず記事を見る" : "먼저 글 보기") : (locale === "zh-tw" ? "先看手機比較" : locale === "en" ? "Start with mobile comparisons" : locale === "ja" ? "まず携帯比較を見る" : "먼저 휴대폰 비교 보기")}
        description={description}
      />
      <CategoryCard
        href={localizePath(locale, "/submit-place")}
        title={locale === "zh-tw" ? "推薦實用地點" : locale === "en" ? "Suggest a useful place" : locale === "ja" ? "役立つ場所を投稿" : "유용한 장소 추천"}
        description={locale === "zh-tw" ? "你的經驗可以幫助下一個剛到日本的人。" : locale === "en" ? "Your practical notes can help the next newcomer." : locale === "ja" ? "あなたの実用的な経験が次の人の助けになります。" : "당신의 실용적인 경험이 다음 사람에게 도움이 됩니다."}
      />
    </div>
  </section>
</BaseLayout>
