---
import { getCollection } from "astro:content";
import BaseLayout from "@/components/layout/BaseLayout.astro";
import CategoryCard from "@/components/content/CategoryCard.astro";
import { htmlLangByLocale, localizePath, sectionCopy, type Locale } from "@/lib/i18n";

interface Props {
  locale: Locale;
  section: "areas" | "tools";
}

const { locale, section } = Astro.props;
const isAreas = section === "areas";
const title = isAreas ? sectionCopy[locale].areasTitle : sectionCopy[locale].toolsTitle;
const description = isAreas
  ? {
      "zh-tw": "用租金感、交通、生活機能、安靜度與適合族群比較東京生活圈，先排除不適合的地區。",
      en: "Compare Tokyo neighborhoods by rent feel, commute, daily convenience, quietness, and fit.",
      ja: "東京のエリアを家賃感、通勤、生活利便性、静かさ、向いている人で比較します。",
      ko: "도쿄 지역을 월세감, 통근, 생활 편의성, 조용함, 적합한 사람 기준으로 비교합니다."
    }[locale]
  : {
      "zh-tw": "提供搬家清單、手機方案比較入口、租屋費用與行政流程等生活決策工具。",
      en: "Static tools and checklists for moving, mobile plan decisions, renting costs, and procedures.",
      ja: "引っ越し、携帯プラン、賃貸費用、手続きの判断に使える静的ツールとチェックリストです。",
      ko: "이사, 휴대폰 요금제, 임대 비용, 행정 절차 판단에 사용할 수 있는 정적 도구와 체크리스트입니다."
    }[locale];
const areas = isAreas ? await getCollection("areas") : [];
const tools = isAreas ? [] : await getCollection("tools", ({ data }) => data.status === "published");
const site = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = new URL(Astro.url.pathname, site).href;
const collectionItems = isAreas
  ? areas.map((area) => ({
      url: new URL(localizePath(locale, `/areas/${area.data.slug}`), site).href,
      name: area.data.title,
      description: area.data.summary
    }))
  : tools.map((tool) => ({
      url: new URL(localizePath(locale, `/tools/${tool.data.slug}`), site).href,
      name: tool.data.title[locale],
      description: tool.data.description[locale]
    }));
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": `${canonicalUrl}#webpage`,
    name: title,
    description,
    url: canonicalUrl,
    inLanguage: htmlLangByLocale[locale],
    isPartOf: { "@id": new URL("/#website", site).href },
    publisher: { "@id": new URL("/#organization", site).href }
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "@id": `${canonicalUrl}#${section}-list`,
    name: title,
    description,
    numberOfItems: collectionItems.length,
    itemListElement: collectionItems.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: item.url,
      name: item.name,
      description: item.description
    }))
  }
];
const areaLabels = {
  "zh-tw": {
    stations: "主要車站",
    rent: "租金感",
    food: "生活/外食",
    commute: "交通",
    quietness: "安靜度",
    fit: "適合",
    warnings: "注意"
  },
  en: {
    stations: "Stations",
    rent: "Rent feel",
    food: "Food/life",
    commute: "Commute",
    quietness: "Quietness",
    fit: "Good for",
    warnings: "Watchouts"
  },
  ja: {
    stations: "主な駅",
    rent: "家賃感",
    food: "生活/外食",
    commute: "交通",
    quietness: "静かさ",
    fit: "向いている人",
    warnings: "注意点"
  },
  ko: {
    stations: "주요 역",
    rent: "월세감",
    food: "생활/외식",
    commute: "교통",
    quietness: "조용함",
    fit: "추천 대상",
    warnings: "주의"
  }
}[locale];
---

<BaseLayout locale={locale} title={title} description={description} jsonLd={jsonLd}>
  <section class="page-hero">
    <div class="container">
      <h1>{title}</h1>
      <p>{description}</p>
    </div>
  </section>
  {isAreas && (
    <section class="section">
      <div class="container section-header">
        <div>
          <h2>{locale === "zh-tw" ? "東京生活圈範例" : locale === "en" ? "Tokyo area samples" : locale === "ja" ? "東京エリア例" : "도쿄 지역 예시"}</h2>
          <p>{locale === "zh-tw" ? "這些不是觀光推薦，而是用來判斷生活成本、通勤與日常便利性的起點。" : locale === "en" ? "These are not sightseeing picks. They are starting points for judging cost, commute, and daily convenience." : locale === "ja" ? "観光ではなく、生活費、通勤、日常利便性を判断するための入口です。" : "관광 추천이 아니라 생활비, 통근, 일상 편의성을 판단하기 위한 시작점입니다."}</p>
        </div>
      </div>
      <div class="container grid grid-2">
        {areas.map((area) => (
          <article class="notice area-card">
            <h2><a href={localizePath(locale, `/areas/${area.data.slug}`)}>{area.data.title}</a></h2>
            <p>{area.data.summary}</p>
            <p>{area.data.prefecture} · {area.data.stations.join(", ")}</p>
            <dl class="detail-list compact-list">
              <dt>{areaLabels.rent}</dt>
              <dd>{area.data.rentLevel}</dd>
              <dt>{areaLabels.food}</dt>
              <dd>{area.data.foodLevel}</dd>
              <dt>{areaLabels.commute}</dt>
              <dd>{area.data.commuteConvenience}</dd>
              <dt>{areaLabels.quietness}</dt>
              <dd>{area.data.quietness}</dd>
            </dl>
            <div class="content-stack">
              <p><strong>{areaLabels.fit}:</strong> {area.data.recommendedFor.join(", ")}</p>
              <p><strong>{areaLabels.warnings}:</strong> {area.data.warnings.join(" ")}</p>
              <p><a class="text-link" href={localizePath(locale, `/areas/${area.data.slug}`)}>{locale === "zh-tw" ? "查看地區詳情" : locale === "en" ? "View area details" : locale === "ja" ? "エリア詳細を見る" : "지역 자세히 보기"}</a></p>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}
  {!isAreas && (
    <section class="section">
      <div class="container section-header">
        <div>
          <h2>{locale === "zh-tw" ? "可用工具" : locale === "en" ? "Available tools" : locale === "ja" ? "利用できるツール" : "사용 가능한 도구"}</h2>
          <p>{locale === "zh-tw" ? "先從不需要登入、不儲存資料的靜態清單開始。" : locale === "en" ? "Start with static tools that do not require login or store your data." : locale === "ja" ? "ログイン不要、データ保存なしの静的ツールから始めます。" : "로그인이나 데이터 저장 없이 사용할 수 있는 정적 도구부터 시작합니다."}</p>
        </div>
      </div>
      <div class="container grid grid-2">
        {tools.map((tool) => (
          <CategoryCard
            href={localizePath(locale, `/tools/${tool.data.slug}`)}
            title={tool.data.title[locale]}
            description={tool.data.description[locale]}
          />
        ))}
      </div>
    </section>
  )}
  <section class="section">
    <div class="container grid grid-2">
      <CategoryCard
        href={localizePath(locale, isAreas ? "/articles" : "/mobile")}
        title={isAreas ? (locale === "zh-tw" ? "先看生活文章" : locale === "en" ? "Start with articles" : locale === "ja" ? "まず記事を見る" : "먼저 글 보기") : (locale === "zh-tw" ? "先看手機比較" : locale === "en" ? "Start with mobile comparisons" : locale === "ja" ? "まず携帯比較を見る" : "먼저 휴대폰 비교 보기")}
        description={description}
      />
      <CategoryCard
        href={localizePath(locale, "/submit-place")}
        title={locale === "zh-tw" ? "推薦實用地點" : locale === "en" ? "Suggest a useful place" : locale === "ja" ? "役立つ場所を投稿" : "유용한 장소 추천"}
        description={locale === "zh-tw" ? "你的經驗可以幫助下一個剛到日本的人。" : locale === "en" ? "Your practical notes can help the next newcomer." : locale === "ja" ? "あなたの実用的な経験が次の人の助けになります。" : "당신의 실용적인 경험이 다음 사람에게 도움이 됩니다."}
      />
    </div>
  </section>
</BaseLayout>
