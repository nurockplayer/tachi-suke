---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import LoginPrompt from "@/components/auth/LoginPrompt.astro";
import FavoriteButtonPlaceholder from "@/components/favorites/FavoriteButtonPlaceholder.astro";
import { sectionCopy, type Locale } from "@/lib/i18n";

interface Props {
  locale: Locale;
  page: "login" | "favorites" | "submissions";
}

const { locale, page } = Astro.props;
const title =
  page === "login"
    ? sectionCopy[locale].accountLoginTitle
    : page === "favorites"
      ? sectionCopy[locale].accountFavoritesTitle
      : sectionCopy[locale].accountSubmissionsTitle;

const body = {
  login: {
    "zh-tw": "未來會支援 Supabase Auth 登入。第一版先保留頁面與導覽。",
    en: "Supabase Auth login will be supported later. The MVP keeps the route and navigation ready.",
    ja: "将来 Supabase Auth によるログインを追加予定です。第一版ではページと導線を保留します。",
    ko: "향후 Supabase Auth 로그인을 지원할 예정입니다. MVP에서는 페이지와 이동 경로를 준비합니다."
  },
  favorites: {
    "zh-tw": "未來可以查看收藏文章、店家、手機方案、地區與工具。",
    en: "Later, you will be able to view saved articles, places, mobile plans, areas, and tools.",
    ja: "将来、保存した記事、お店、携帯プラン、エリア、ツールを確認できます。",
    ko: "나중에 저장한 글, 장소, 휴대폰 요금제, 지역, 도구를 볼 수 있습니다."
  },
  submissions: {
    "zh-tw": "未來可以查看自己的投稿狀態，例如 pending_review、approved、rejected、needs_more_info。",
    en: "Later, you will be able to view your submission status, such as pending_review, approved, rejected, or needs_more_info.",
    ja: "将来、自分の投稿状況を pending_review、approved、rejected、needs_more_info などで確認できます。",
    ko: "나중에 pending_review, approved, rejected, needs_more_info 같은 추천 상태를 확인할 수 있습니다."
  }
}[page][locale];
---

<BaseLayout locale={locale} title={title} description={body} robots="noindex, nofollow">
  <section class="page-hero">
    <div class="container">
      <h1>{title}</h1>
      <p>{body}</p>
    </div>
  </section>
  <section class="section">
    <div class="container grid grid-2">
      <LoginPrompt locale={locale} />
      <aside class="notice">
        <h2>{page === "favorites" ? title : "TachiSuke"}</h2>
        <p>{body}</p>
        {page === "favorites" && <FavoriteButtonPlaceholder locale={locale} />}
      </aside>
    </div>
  </section>
</BaseLayout>
