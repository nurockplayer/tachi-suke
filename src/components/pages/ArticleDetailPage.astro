---
import { getCollection, render, type CollectionEntry } from "astro:content";
import ArticleLayout from "@/components/layout/ArticleLayout.astro";
import { localizePath, type Locale } from "@/lib/i18n";

interface Props {
  article: CollectionEntry<"articles">;
}

const { article } = Astro.props;
const { Content, headings } = await render(article);
const allArticles = await getCollection("articles");
const translations = allArticles.filter(
  (entry) => entry.data.translationKey === article.data.translationKey && !entry.data.draft
);
const alternatePaths = Object.fromEntries(
  translations.map((entry) => [entry.data.locale, localizePath(entry.data.locale, `/articles/${entry.data.slug}`)])
) as Partial<Record<Locale, string>>;
const relatedArticles = allArticles
  .filter((entry) => entry.id !== article.id && entry.data.locale === article.data.locale && !entry.data.draft)
  .map((entry) => {
    const sharedTags = entry.data.tags.filter((tag) => article.data.tags.includes(tag)).length;
    const score = (entry.data.category === article.data.category ? 100 : 0) + sharedTags * 10;
    return { entry, score };
  })
  .sort((a, b) => b.score - a.score || b.entry.data.updatedAt.getTime() - a.entry.data.updatedAt.getTime())
  .slice(0, 3)
  .map(({ entry }) => ({
    title: entry.data.title,
    description: entry.data.description,
    href: localizePath(entry.data.locale, `/articles/${entry.data.slug}`)
  }));
---

<ArticleLayout
  locale={article.data.locale}
  title={article.data.title}
  description={article.data.description}
  category={article.data.category}
  tags={article.data.tags}
  publishedAt={article.data.publishedAt}
  updatedAt={article.data.updatedAt}
  alternatePaths={alternatePaths}
  headings={headings}
  relatedArticles={relatedArticles}
  sourceLinks={article.data.sourceLinks}
>
  <Content />
</ArticleLayout>
