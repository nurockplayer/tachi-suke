---
import { localizePath, type Locale } from "@/lib/i18n";
import {
  japaneseDifficultyLabels,
  nonSmokingStatusLabels,
  placeFieldLabels,
  soloFriendlyLabels
} from "@/lib/places";
import type { JapaneseDifficulty, NonSmokingStatus, SoloFriendly } from "@/types/place";

interface Props {
  place: {
    id?: string;
    data?: {
      slug: string;
      name: string;
      category: string;
      prefecture: string;
      city: string;
      area: string;
      station: string;
      priceRange: string;
      soloFriendly: SoloFriendly;
      nonSmokingStatus: NonSmokingStatus;
      japaneseDifficulty: JapaneseDifficulty;
      paymentMethods: string[];
      googleMapUrl?: string;
      officialUrl?: string;
    };
    slug?: string;
    name?: string;
    category?: string;
    prefecture?: string;
    city?: string;
    area?: string;
    station?: string;
    priceRange?: string;
    soloFriendly?: SoloFriendly;
    nonSmokingStatus?: NonSmokingStatus;
    japaneseDifficulty?: JapaneseDifficulty;
    paymentMethods?: string[];
    googleMapUrl?: string;
    officialUrl?: string;
  };
  locale: Locale;
}

const { place, locale } = Astro.props;
const data = place.data ?? place;
const labels = placeFieldLabels[locale];
const slug = data.slug ?? place.id;
const detailHref = slug ? localizePath(locale, `/places/${slug}`) : undefined;
const soloFriendly = data.soloFriendly ? soloFriendlyLabels[locale][data.soloFriendly] : soloFriendlyLabels[locale].unknown;
const nonSmokingStatus = data.nonSmokingStatus
  ? nonSmokingStatusLabels[locale][data.nonSmokingStatus]
  : nonSmokingStatusLabels[locale].unknown;
const japaneseDifficulty = data.japaneseDifficulty
  ? japaneseDifficultyLabels[locale][data.japaneseDifficulty]
  : japaneseDifficultyLabels[locale].unknown;
---

<article class="place-card">
  <h3>{detailHref ? <a href={detailHref}>{data.name}</a> : data.name}</h3>
  <p>{[data.category, data.area, data.station].filter(Boolean).join(" · ")}</p>
  <div class="place-tags" aria-label="Place facts">
    {data.priceRange && <span>{data.priceRange}</span>}
    <span>{labels.soloFriendly}: {soloFriendly}</span>
    <span>{labels.nonSmokingStatus}: {nonSmokingStatus}</span>
    <span>{labels.japaneseDifficulty}: {japaneseDifficulty}</span>
  </div>
  {detailHref && <p><a class="text-link" href={detailHref}>{labels.details}</a></p>}
</article>
