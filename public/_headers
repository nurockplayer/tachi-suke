/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self'; form-action 'self' https:; upgrade-insecure-requests
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Cache-Control: public, max-age=0, must-revalidate

/_astro/*
  ! Cache-Control
  Cache-Control: public, max-age=31536000, immutable

/images/*
  ! Cache-Control
  Cache-Control: public, max-age=604800

/sitemap.xml
  ! Cache-Control
  Cache-Control: public, max-age=3600

/robots.txt
  ! Cache-Control
  Cache-Control: public, max-age=3600

/llms.txt
  ! Cache-Control
  Cache-Control: public, max-age=3600

/.well-known/security.txt
  ! Cache-Control
  Cache-Control: public, max-age=3600

/opensearch.xml
  ! Cache-Control
  Cache-Control: public, max-age=3600

/site.webmanifest
  ! Cache-Control
  Cache-Control: public, max-age=3600

/feed.xml
  ! Cache-Control
  Cache-Control: public, max-age=3600

/zh-tw/feed.xml
  ! Cache-Control
  Cache-Control: public, max-age=3600

/en/feed.xml
  ! Cache-Control
  Cache-Control: public, max-age=3600

/ja/feed.xml
  ! Cache-Control
  Cache-Control: public, max-age=3600

/ko/feed.xml
  ! Cache-Control
  Cache-Control: public, max-age=3600

/zh-tw/search-index.json
  ! Cache-Control
  Cache-Control: public, max-age=3600

/en/search-index.json
  ! Cache-Control
  Cache-Control: public, max-age=3600

/ja/search-index.json
  ! Cache-Control
  Cache-Control: public, max-age=3600

/ko/search-index.json
  ! Cache-Control
  Cache-Control: public, max-age=3600
